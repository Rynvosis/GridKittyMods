#			name = "ethic_line_gestalt"
#			spriteType = "GFX_line_horizontal"
#			position = { x = 57 y = 215 }
#			scale = 0.75
#		}

		### SELECTED ETHICS ###

		iconType = {
			name = "ethic_col_selected"
			spriteType = "GFX_ethic_selected"
		}

		iconType = {
			name = "ethic_str_selected"
			spriteType = "GFX_ethic_selected"
		}

		iconType = {
			name = "ethic_xen_selected"
			spriteType = "GFX_ethic_selected"
		}

		iconType = {
			name = "ethic_mil_selected"
			spriteType = "GFX_ethic_selected"
		}

		iconType = {
			name = "ethic_spi_selected"
			spriteType = "GFX_ethic_selected"
		}

		iconType = {
			name = "ethic_hive_selected"
			spriteType = "GFX_ethic_selected"
		}
	}

	### GOVERNMENT AUTHORITY ###

	containerWindowType = {
		name = "government_authority_header"
		position = { x = 350 y = 0 }

		iconType = {
			name = "hex_bg"
			spriteType = "GFX_hex_bg"
			position = { x = -10 y = -8 }
			alwaysTransparent = yes
		}

		iconType = {
			name = "header_line"
			spriteType = "GFX_line"
			position = { x = 6 y = 26 }
		}

		instantTextBoxType = {
			name = "label"
			font = "malgun_goth_24"
			position = { x = 16 y = 7 }
			maxWidth = 400
			text =	 "GOVERNMENT_AUTHORITY"
			format = left
			alwaysTransparent = yes
		}
	}

	gridBoxType = {
		name = "authority_grid"
		position = { x = 362 y = 50 }
		size = { width = 300 height = 50 }
		slotSize = { width = 50 height = 50 }
		max_slots_horizontal = 5
		format = CENTERED_UP
		add_horizontal = yes
	}

	containerWindowType = {
		name = "authority_description"
		size = { width = 310 height = 131 }
		position = { x = 360 y = 160 }

		background = {
			name = "background"
			spriteType = "GFX_tiles_dark_area_cut_8"
			alwaysTransparent = yes
		}

		instantTextBoxType = {
			name = "desc"
			font = "cg_16b"
			position = { x = 10 y = 10 }
			maxWidth = 290
			maxHeight = 111
			text = ""
			scrollbartype = "standardtext_slider"
		}
	}

	instantTextBoxType = {
		name = "government_type"
		font = "malgun_goth_24"
		position = { x = 360 y = 300 }
		maxWidth = 310
		maxHeight = 20
		text =	""
		format = center
	}

	### GOVERNMENT CIVICS ###

	containerWindowType = {
		name = "civics_header"
		position = { x = 700 y = 0 }

		iconType = {
			name = "hex_bg"
			spriteType = "GFX_hex_bg"
			position = { x = -10 y = -8 }
			alwaysTransparent = yes
		}

		iconType = {
