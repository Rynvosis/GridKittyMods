# Version last updated: v4.3.0
# Overrides empire_ethics_and_government_editor from customize_species_editors.gui
# Adds Stratified/Pluralist ethic axis to the ethics picker

@movable_editors = no

@sub_window_pos_x = -405
@sub_window_pos_y = -50
@sub_window_height = 405
@sub_window_width = 1040

# Ethics grid X positions (50px spacing, centered in 310px)
@e_x0 = 70
@e_x1 = 105
@e_x2 = 135
@e_x3 = 165
@e_x4 = 200

# Ethics grid Y positions (38px spacing, one row per axis)
@e_y0 = 0
@e_y1 = 38
@e_y2 = 76
@e_y3 = 114
@e_y4 = 152
@e_yg = 190

guiTypes = {
	containerWindowType = {
		name = "empire_ethics_and_government_editor"
	moveable = @movable_editors
	position = { x = @sub_window_pos_x y = @sub_window_pos_y }
	size = { width = @sub_window_width height = @sub_window_height }
	orientation = center

	background = {
		name = "background"
		spriteType = "GFX_subwindow_tile_plain_solid"
	}

	### ETHICS ###

	containerWindowType = {
		name = "ethics_header"

		iconType = {
			name = "hex_bg"
			spriteType = "GFX_hex_bg"
			position = { x = -10 y = -8 }
			alwaysTransparent = yes
		}

		iconType = {
			name = "header_line"
			spriteType = "GFX_line"
			position = { x = 6 y = 26 }
		}

		instantTextBoxType = {
			name = "label"
			font = "malgun_goth_24"
			position = { x = 16 y = 7 }
			maxWidth = 400
			text =	 "empire_ethics_editor"
			format = left
			alwaysTransparent = yes
		}
	}

	containerWindowType = {
		name = "ethics"
		size = { width = 310 height = 300 }
		position = { x = 5 y = 68 }

		### ETHIC POINTS ###

		instantTextBoxType = {
			name = "ethic_points_left"
			position = { x = 0 y = 232 }
			font = "malgun_goth_24"
			maxWidth = 310
			maxHeight = 20
			text = "POINTS_LEFT_ETHICS"
			format = center
		}

		### SEPARATOR LINES ###

		iconType = {
			name = "ethic_line_0"
			spriteType = "GFX_line_horizontal"
			position = { x = 57 y = -13 }
			scale = 0.75
		}

		iconType = {
			name = "ethic_line_1"
			spriteType = "GFX_line_horizontal"
			position = { x = 57 y = 25 }
			scale = 0.75
		}

		iconType = {
			name = "ethic_line_2"
			spriteType = "GFX_line_horizontal"
			position = { x = 57 y = 63 }
			scale = 0.75
		}

		iconType = {
			name = "ethic_line_3"
			spriteType = "GFX_line_horizontal"
			position = { x = 57 y = 101 }
			scale = 0.75
