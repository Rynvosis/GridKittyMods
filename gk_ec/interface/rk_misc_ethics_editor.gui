			spriteType = "GFX_ethics_fanatic_egalitarian"
			position = { x = @e_x4 y = @e_y0 }
			clicksound = interface
		}

		### AXIS 1: STRATIFIED ↔ PLURALIST ###

		buttonType = {
			name = "ethic_fanatic_stratified"
			spriteType = "GFX_ethics_fanatic_stratified"
			position = { x = @e_x0 y = @e_y1 }
			clicksound = interface
		}

		buttonType = {
			name = "ethic_stratified"
