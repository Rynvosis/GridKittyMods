		iconType = {
			name = "ethic_line_4"
			spriteType = "GFX_line_horizontal"
			position = { x = 57 y = 139 }
			scale = 0.75
		}

		iconType = {
			name = "ethic_line_5"
			spriteType = "GFX_line_horizontal"
			position = { x = 57 y = 177 }
			scale = 0.75
		}

		### AXIS 0: AUTHORITARIAN ↔ EGALITARIAN ###

		buttonType = {
			name = "ethic_fanatic_authoritarian"
			spriteType = "GFX_ethics_fanatic_authoritarian"
			position = { x = @e_x0 y = @e_y0 }
			clicksound = interface
		}

		buttonType = {
			name = "ethic_authoritarian"
			spriteType = "GFX_ethics_authoritarian"
			position = { x = @e_x1 y = @e_y0 }
			clicksound = interface
