			spriteType = "GFX_ethics_fanatic_pluralist"
			position = { x = @e_x4 y = @e_y1 }
			clicksound = interface
		}

		### AXIS 2: XENOPHOBE ↔ XENOPHILE ###

		buttonType = {
			name = "ethic_fanatic_xenophobe"
			spriteType = "GFX_ethics_fanatic_xenophobe"
