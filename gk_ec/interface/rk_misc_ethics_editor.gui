			format = left
			alwaysTransparent = yes
		}
	}

	containerWindowType = {
		name = "civics"
		size = { width = 310 height = 223 }
		position = { x = 710 y = 50 }

		background = {
			name = "dark_area_bg"
			spriteType = "GFX_tiles_dark_area_cut_8"
			alwaysTransparent = yes
		}

		smoothListboxType = {
			name = "selected_entries"
			position = { x = 8 y = 8 }
			size = { x = 294 y = 207 }
			scrollbarType = "standardlistbox_slider"
			borderSize = { x = 0 y = 0 }
			spacing = 3
		}

		smoothListboxType = {
			name = "available_entries"
			position = { x = 8 y = 15 }
			size = { x = 294 y = 207 }
			scrollbarType = "standardlistbox_slider"
			borderSize = { x = 0 y = 0 }
			spacing = 3
		}
	}

	instantTextBoxType = {
